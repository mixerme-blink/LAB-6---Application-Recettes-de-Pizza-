<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp"
    android:background="@android:color/white">

    <!-- Image de la pizza à gauche -->
    <ImageView
        android:id="@+id/imgPizza"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:scaleType="centerCrop"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"/>

    <!-- Nom de la pizza -->
    <TextView
        android:id="@+id/tvNom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toRightOf="@id/imgPizza"
        android:layout_toLeftOf="@id/imgFavorite"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="#333333"/>

    <!-- Icône prix -->
    <ImageView
        android:id="@+id/iconPrix"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@android:drawable/ic_menu_myplaces"
        android:layout_toRightOf="@id/imgPizza"
        android:layout_below="@id/tvNom"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp"/>

    <!-- Prix -->
    <TextView
        android:id="@+id/tvPrix"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toRightOf="@id/iconPrix"
        android:layout_below="@id/tvNom"
        android:layout_marginStart="4dp"
        android:layout_marginTop="6dp"
        android:textSize="13sp"
        android:textColor="#666666"/>

    <!-- Icône horloge -->
    <ImageView
        android:id="@+id/iconDuree"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@android:drawable/ic_menu_recent_history"
        android:layout_toRightOf="@id/imgPizza"
        android:layout_below="@id/tvPrix"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"/>

    <!-- Durée -->
    <TextView
        android:id="@+id/tvDuree"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toRightOf="@id/iconDuree"
        android:layout_below="@id/tvPrix"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:textSize="13sp"
        android:textColor="#666666"/>

    <!-- Icône flèche/favoris à droite -->
    <ImageView
        android:id="@+id/imgFavorite"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@android:drawable/ic_menu_share"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="8dp"/>

</RelativeLayout>